diff --git a/av1/encoder/bitstream.c b/av1/encoder/bitstream.c
index 53ca4ad..9c36177 100644
--- a/av1/encoder/bitstream.c
+++ b/av1/encoder/bitstream.c
@@ -14,6 +14,7 @@
 #include <stdbool.h>
 #include <stdint.h>
 #include <stdio.h>
+#include <stdlib.h>
 #include <string.h>
 
 #include "aom/aom_encoder.h"
@@ -55,6 +56,62 @@
 #define SETUP_TIME_OH_CONST 5     // Setup time overhead constant per worker
 #define JOB_DISP_TIME_OH_CONST 1  // Job dispatch time overhead per tile
 
+#if defined(FRAMEFORGE_LIBAOM_SB_BITS) && FRAMEFORGE_LIBAOM_SB_BITS
+static FILE *frameforge_libaom_sb_bits_file(void) {
+  static int initialized = 0;
+  static FILE *file = NULL;
+  if (!initialized) {
+    const char *path = getenv("FRAMEFORGE_LIBAOM_SB_BITS");
+    initialized = 1;
+    if (path != NULL && path[0] != '\0' && strcmp(path, "0") != 0) {
+      if (strcmp(path, "-") == 0) {
+        file = stderr;
+      } else {
+        file = fopen(path, "a");
+        if (file == NULL) {
+          fprintf(stderr, "failed to open FRAMEFORGE_LIBAOM_SB_BITS=%s\n",
+                  path);
+        }
+      }
+    }
+  }
+  return file;
+}
+
+static void frameforge_libaom_report_sb_bits(const AV1_COMP *const cpi,
+                                             const TileInfo *const tile,
+                                             int tile_row, int tile_col,
+                                             int mi_row, int mi_col,
+                                             int before_bits,
+                                             int after_bits) {
+  FILE *const file = frameforge_libaom_sb_bits_file();
+  if (file == NULL) return;
+
+  const AV1_COMMON *const cm = &cpi->common;
+  const int sb_mi = cm->seq_params->mib_size;
+  const int visible_mi_w = AOMMIN(sb_mi, cm->mi_params.mi_cols - mi_col);
+  const int visible_mi_h = AOMMIN(sb_mi, cm->mi_params.mi_rows - mi_row);
+  const int x = mi_col * MI_SIZE;
+  const int y = mi_row * MI_SIZE;
+  const int width = visible_mi_w * MI_SIZE;
+  const int height = visible_mi_h * MI_SIZE;
+  const int sb_size = sb_mi * MI_SIZE;
+  const int total_bits = after_bits >= before_bits ? after_bits - before_bits
+                                                   : 0;
+
+  fprintf(file,
+          "{\"codec\":\"av1\",\"source\":\"libaom\",\"frame_index\":%u,"
+          "\"tile_row\":%d,\"tile_col\":%d,\"tile_origin_x\":%d,"
+          "\"tile_origin_y\":%d,\"sb_x\":%d,\"sb_y\":%d,\"x\":%d,\"y\":%d,"
+          "\"width\":%d,\"height\":%d,\"superblock_size\":%d,"
+          "\"before_bits\":%d,\"after_bits\":%d,\"total_symbol_bits\":%d}\n",
+          cm->current_frame.frame_number, tile_row, tile_col,
+          tile->mi_col_start * MI_SIZE, tile->mi_row_start * MI_SIZE,
+          x / sb_size, y / sb_size, x, y, width, height, sb_size, before_bits,
+          after_bits, total_bits);
+}
+#endif
+
 static inline void write_uniform(aom_writer *w, int n, int v) {
   const int l = get_unsigned_bits(n);
   const int m = (1 << l) - n;
@@ -1764,8 +1821,16 @@ static inline void write_modes(AV1_COMP *const cpi, ThreadData *const td,
     for (int mi_col = mi_col_start; mi_col < mi_col_end;
          mi_col += cm->seq_params->mib_size) {
       td->mb.cb_coef_buff = av1_get_cb_coeff_buffer(cpi, mi_row, mi_col);
+#if defined(FRAMEFORGE_LIBAOM_SB_BITS) && FRAMEFORGE_LIBAOM_SB_BITS
+      const int frameforge_sb_start_bits = aom_tell_size(w);
+#endif
       write_modes_sb(cpi, td, tile, w, &tok, tok_end, mi_row, mi_col,
                      cm->seq_params->sb_size);
+#if defined(FRAMEFORGE_LIBAOM_SB_BITS) && FRAMEFORGE_LIBAOM_SB_BITS
+      frameforge_libaom_report_sb_bits(cpi, tile, tile_row, tile_col, mi_row,
+                                       mi_col, frameforge_sb_start_bits,
+                                       aom_tell_size(w));
+#endif
     }
     assert(tok == tok_end);
   }
